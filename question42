#include <stdio.h>

#define MAX 100

int queue[MAX];
int front = 0, rear = -1;

int stack[MAX];
int top = -1;

// enqueue
void enqueue(int x) {
    queue[++rear] = x;
}

// dequeue
int dequeue() {
    return queue[front++];
}

// push to stack
void push(int x) {
    stack[++top] = x;
}

// pop from stack
int pop() {
    return stack[top--];
}

int main() {
    int n;
    scanf("%d", &n);

    // input queue
    for(int i = 0; i < n; i++) {
        int x;
        scanf("%d", &x);
        enqueue(x);
    }

    // Step 1: queue → stack
    while(front <= rear) {
        push(dequeue());
    }

    // reset queue
    front = 0;
    rear = -1;

    // Step 2: stack → queue
    while(top != -1) {
        enqueue(pop());
    }

    // print reversed queue
    for(int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }

    return 0;
}